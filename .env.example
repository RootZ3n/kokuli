# ──────────────────────────────────────────────────────
# Kokuli environment variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────

# --- Network gate (required for public-target tests) ---
# Both flags must be set to "1" to allow requests to public hosts.
KOKULI_ENABLE_NETWORK_OPS=
KOKULI_OWNERSHIP_CONFIRMED=
# Legacy aliases (also accepted):
# VERUM_ENABLE_NETWORK_OPS=
# VERUM_OWNERSHIP_CONFIRMED=

# --- Network gate bypass (test-only) ---
# Only honored when NODE_ENV=test. Skips the network gate entirely.
KOKULI_NETWORK_BYPASS=

# --- Server ---
# Port for the Kokuli web UI (default: 3000)
KOKULI_PORT=
# Host to bind to (default: 127.0.0.1)
KOKULI_HOST=
# Set to "1" to bind on all interfaces (0.0.0.0)
KOKULI_BIND_ALL=

# --- Target config override ---
# Custom path to targets.json (default: config/targets.json)
KRAKZEN_TARGETS_PATH=

# --- AI Judge (optional) ---
# Disabled by default. Set to "true" (or "1") to enable advisory AI review
# only for ambiguous deterministic WARN results. Definitive PASS/FAIL results
# are never overridden.
KOKULI_AI_JUDGE=
KOKULI_AI_JUDGE_PROVIDER=
KOKULI_AI_JUDGE_MODEL=
KOKULI_AI_JUDGE_BASE_URL=
KOKULI_AI_JUDGE_API_KEY=
KOKULI_AI_JUDGE_TIMEOUT_MS=

# --- Peh / Ptah roots (used by bridge commands) ---
# Path to the Peh repository root (default: /mnt/ai/peh)
PEH_ROOT=
# Path to the Ptah repository root (default: /mnt/ai/ptah)
PTAH_ROOT=

# --- Bridge ---
# TTL in milliseconds for bridge run state (default: system default)
KOKULI_BRIDGE_RUN_TTL_MS=

# --- Ledger ---
# Max ledger entries to retain (default: system default)
LEDGER_MAX_ENTRIES=
# Ledger retention period in days (default: system default)
LEDGER_RETENTION_DAYS=
