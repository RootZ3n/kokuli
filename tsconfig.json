{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "velum-ai": ["../velum/dist/index.d.ts"],
      "velum-ai/*": ["../velum/dist/*"]
    },
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "engine/**/*.ts",
    "learning/**/*.ts",
    "server/**/*.ts",
    "providers/**/*.ts",
    "config/**/*.json",
    "tests/**/*.json"
  ]
}
