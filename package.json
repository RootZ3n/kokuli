{
  "name": "krakzen",
  "version": "0.2.0",
  "private": true,
  "description": "Krakzen - adversarial validation and training framework for Squidley",
  "main": "dist/cli.js",
  "type": "commonjs",
  "bin": {
    "krakzen": "./bin/krakzen.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node --transpile-only engine/cli.ts",
    "web": "ts-node --transpile-only server/index.ts",
    "run:test": "ts-node engine/cli.ts run",
    "run:suite": "ts-node engine/cli.ts suite",
    "report:latest": "ts-node engine/cli.ts report latest",
    "install:local": "bash install/install.sh",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "axios": "^1.7.9",
    "chalk": "^4.1.2",
    "express": "^5.2.1",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
