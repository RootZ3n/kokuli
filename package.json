{
  "name": "verum",
  "version": "0.2.0",
  "private": true,
  "description": "Verum - adversarial validation and training framework for Squidley",
  "main": "dist/cli.js",
  "type": "commonjs",
  "bin": {
    "krakzen": "./bin/krakzen.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -r server/public dist/server/public",
    "dev": "npm run build --silent && node dist/engine/cli.js",
    "web": "npm run build --silent && node dist/server/index.js",
    "run:test": "ts-node engine/cli.ts run",
    "run:suite": "ts-node engine/cli.ts suite",
    "test:logic": "node --test -r ts-node/register engine/assessment.test.ts engine/targets.test.ts server/public/js/api-client.test.js server/public/js/target-form.test.js",
    "report:latest": "ts-node engine/cli.ts report latest",
    "install:local": "bash install/install.sh",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "axios": "^1.7.9",
    "chalk": "^4.1.2",
    "express": "^5.2.1",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
